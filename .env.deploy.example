# Copy to .env.deploy.local and fill in values, then run: pnpm env:push
# Never commit .env.deploy.local (gitignored via .env*.local)

# ── Vercel (Next.js frontend) ─────────────────────────────────────
# Get these after: npx convex login && npx convex deploy
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=prod:your-deployment-name

# Optional: Vercel build integration (Convex dashboard → Project Settings → Deploy Key)
# CONVEX_DEPLOY_KEY=

# ── Convex backend (contact form / Resend) ────────────────────────
# Set on Convex with: pnpm env:push:convex
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=hades0577dev@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev
