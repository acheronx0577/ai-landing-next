# ── Local dev (Next.js) ───────────────────────────────────────────
# Generated by `npx convex dev` — do not commit real secrets here.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
CONVEX_DEPLOYMENT=

# ── Production deploy (Vercel + Convex) ───────────────────────────
# Copy .env.deploy.example → .env.deploy.local, fill in values, then:
#   pnpm env:push          # push to Vercel + Convex prod
#   pnpm env:push:vercel   # Vercel only
#   pnpm env:push:convex   # Convex prod only
#
# Vercel gets: NEXT_PUBLIC_CONVEX_URL, NEXT_PUBLIC_CONVEX_SITE_URL, CONVEX_DEPLOYMENT
# Convex gets: RESEND_API_KEY, CONTACT_TO_EMAIL, CONTACT_FROM_EMAIL
#
# Resend keys never go on Vercel — only on the Convex backend.
